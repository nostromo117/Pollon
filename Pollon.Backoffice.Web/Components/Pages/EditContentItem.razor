@page "/content-items/new"
@page "/content-items/edit/{Id}"
@rendermode InteractiveServer
@inject BackofficeApiClient ApiClient
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>@(IsEdit ? "Edit Content Item" : "New Content Item")</PageTitle>

<PageTitle>@(IsEdit ? "Edit Content Item" : "New Content Item")</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@(IsEdit ? "Edit Content Item" : "New Content Item")</MudText>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <EditForm Model="item" OnValidSubmit="HandleSubmit" FormName="ModifyContentItem">
        <MudGrid>
            <!-- Left column: Main Content Fields -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Configuration</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="mb-4">
                            @if (IsEdit)
                            {
                                <MudTextField Value="@GetContentTypeName(item.ContentTypeId)" Label="Content Type" ReadOnly="true" Variant="Variant.Outlined" />
                            }
                            else
                            {
                                <MudSelect T="string" Label="Content Type" @bind-Value="item.ContentTypeId" Variant="Variant.Outlined" @bind-Value:after="OnContentTypeChanged">
                                    <MudSelectItem Value="@("")">-- Select Content Type --</MudSelectItem>
                                    @foreach(var ct in contentTypes)
                                    {
                                        <MudSelectItem Value="@ct.Id">@ct.DisplayName (@ct.SystemName)</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </div>

                        <!-- Dynamic Fields -->
                        @if (selectedContentType != null && selectedContentType.Fields.Any())
                        {
                            <MudDivider Class="my-6" />
                            <MudText Typo="Typo.h6" Class="mb-4">Content Data</MudText>

                            <MudGrid>
                                @foreach (var field in selectedContentType.Fields)
                                {
                                    <MudItem xs="12">
                                        @if (field.FieldType == ContentFieldType.Boolean)
                                        {
                                            <MudSwitch T="bool" Value="@GetBoolValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Color="Color.Primary" Label="@field.Name" Class="mt-2" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Number)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" InputType="InputType.Number" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Date)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" InputType="InputType.Date" />
                                        }
                                        else if (field.FieldType == ContentFieldType.RichText)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" Lines="5" HelperText="Supports HTML content" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Image)
                                        {
                                            <div class="d-flex flex-column gap-2 mb-4">
                                                <MudText Typo="Typo.subtitle2">@field.Name</MudText>
                                                @if (!string.IsNullOrEmpty(GetStringValue(field.Name)))
                                                {
                                                    <MudImage Src="@GetStringValue(field.Name)" Alt="@field.Name" Elevation="2" Class="rounded" Style="max-width: 200px; max-height: 200px; object-fit: cover;" />
                                                }
                                                <div>
                                                    <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                                                        Upload Image
                                                        <InputFile OnChange="@(e => UploadImageAsync(field.Name, e.File))" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none;" />
                                                    </MudButton>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" />
                                        }
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Right column: Metadata & Publishing -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Publishing</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="4">
                            <MudSelect T="string" Label="Status" @bind-Value="item.Status" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                                <MudSelectItem Value="@("Published")">Published</MudSelectItem>
                                <MudSelectItem Value="@("Archived")">Archived</MudSelectItem>
                            </MudSelect>

                            <MudTextField T="string" Label="Slug" @bind-Value="item.Slug" Adornment="Adornment.Start" AdornmentText="/" Variant="Variant.Outlined" HelperText="Used for the item URL." />

                            <MudSelect T="string" Label="Parent Item" @bind-Value="item.ParentId" Variant="Variant.Outlined" Clearable="true" HelperText="Select a parent to nest this content item under it.">
                                <MudSelectItem T="string" Value="@((string?)null)">-- Nessuno --</MudSelectItem>
                                @foreach (var parent in availableParents.Where(p => p.Id != item.Id))
                                {
                                    <MudSelectItem T="string" Value="@parent.Id">@GetItemDisplayName(parent)</MudSelectItem>
                                }
                            </MudSelect>

                            <MudPaper Elevation="0" Class="pa-4 bg-light">
                                <MudText Typo="Typo.subtitle2" Color="Color.Inherit" Class="mb-2">Icon</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudPaper Width="48px" Height="48px" Class="d-flex align-center justify-center border bg-white">
                                        @if (!string.IsNullOrEmpty(item.Icon))
                                        {
                                            <MudIcon Icon="@GetMudIcon(item.Icon)" Color="Color.Primary" Size="Size.Large" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Default" Style="opacity: 0.25" Size="Size.Large" />
                                        }
                                    </MudPaper>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small" OnClick="ShowIconPicker">
                                        Select
                                    </MudButton>
                                    @if (!string.IsNullOrEmpty(item.Icon))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => item.Icon = null" />
                                    }
                                </MudStack>
                            </MudPaper>

                            <MudTextField T="string" Label="Created By" @bind-Value="item.CreatedBy" Variant="Variant.Outlined" />

                            @if (IsEdit)
                            {
                                <MudField Label="Created At" Variant="Variant.Text">@item.CreatedAt.ToLocalTime().ToString("g")</MudField>
                                @if (item.PublishedAt.HasValue)
                                {
                                    <MudField Label="Published At" Variant="Variant.Text">@item.PublishedAt.Value.ToLocalTime().ToString("g")</MudField>
                                }
                                @if (item.UpdatedAt.HasValue)
                                {
                                    <MudField Label="Last Updated" Variant="Variant.Text">@item.UpdatedAt.Value.ToLocalTime().ToString("g")</MudField>
                                }
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="py-3" Disabled="@(string.IsNullOrEmpty(item.ContentTypeId))">Save Content</MudButton>
                    </MudCardActions>
                </MudCard>
                
                <MudButton Href="content-items" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mt-4" FullWidth="true">Back to List</MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>

    <MudDialog @bind-Visible="showIconPicker" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Palette" Class="mr-3"/>Seleziona un'icona</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField T="string" Label="Cerca icona..." @bind-Value="iconSearch" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4" />
            <MudGrid Style="max-height: 400px; overflow-y: auto;">
                @foreach (var icon in FilteredIcons)
                {
                    <MudItem xs="4" sm="2">
                        <MudTooltip Text="@icon.Name">
                            <MudIconButton Icon="@GetMudIcon(icon.Val)" Color="Color.Default" Size="Size.Large" OnClick="() => SelectIcon(icon.Val)" Class="w-100 pa-4 mud-ripple shadow-none border" />
                        </MudTooltip>
                    </MudItem>
                }
            </MudGrid>
        </DialogContent>
    </MudDialog>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private bool isLoading = true;

    private ContentItem item = new() { Status = "Draft", CreatedBy = "System Admin", Data = new() };
    private ContentType[] contentTypes = Array.Empty<ContentType>();
    private ContentItem[] availableParents = Array.Empty<ContentItem>();
    private ContentType? selectedContentType;

    private bool showIconPicker = false;
    private string iconSearch = "";
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private string GetMudIcon(string faClass)
    {
        // Simple mapping or just return the fa class if using MudIcon with Font Awesome
        // MudBlazor supports Font Awesome via the Icon property if you prefix it correctly
        // but it's easier to just use the string class in a standard <i> if needed.
        // However, for consistency, I'll return the class string and use it in a custom way if needed.
        return faClass;
    }

    private readonly List<(string Name, string Val)> AvailableIcons = new()
    {
        ("Casa", "fa-solid fa-home"), ("Utente", "fa-solid fa-user"), ("Articolo", "fa-solid fa-file-lines"),
        ("Immagine", "fa-solid fa-image"), ("Video", "fa-solid fa-video"), ("Musica", "fa-solid fa-music"),
        ("Prezzo", "fa-solid fa-tag"), ("Carrello", "fa-solid fa-cart-shopping"), ("Stella", "fa-solid fa-star"),
        ("Cuore", "fa-solid fa-heart"), ("Check", "fa-solid fa-check"), ("X", "fa-solid fa-xmark"),
        ("Info", "fa-solid fa-info-circle"), ("Attenzione", "fa-solid fa-warning"), ("Razzo", "fa-solid fa-rocket"),
        ("Mappa", "fa-solid fa-map"), ("Telefono", "fa-solid fa-phone"), ("Email", "fa-solid fa-envelope"),
        ("Calendario", "fa-solid fa-calendar"), ("Orologio", "fa-solid fa-clock"), ("Impostazioni", "fa-solid fa-gear"),
        ("Chiave", "fa-solid fa-key"), ("Lucchetto", "fa-solid fa-lock"), ("Grafico", "fa-solid fa-chart-line"),
        ("Nuvola", "fa-solid fa-cloud"), ("Fulmine", "fa-solid fa-bolt"), ("Fuoco", "fa-solid fa-fire"),
        ("Acqua", "fa-solid fa-droplet"), ("Foglia", "fa-solid fa-leaf"), ("Sole", "fa-solid fa-sun")
    };

    private IEnumerable<(string Name, string Val)> FilteredIcons => 
        string.IsNullOrWhiteSpace(iconSearch) 
            ? AvailableIcons 
            : AvailableIcons.Where(i => i.Name.Contains(iconSearch, StringComparison.OrdinalIgnoreCase) || i.Val.Contains(iconSearch, StringComparison.OrdinalIgnoreCase));

    private void ShowIconPicker() => showIconPicker = true;
    private void HideIconPicker() { showIconPicker = false; iconSearch = ""; }
    private void SelectIcon(string icon) { item.Icon = icon; HideIconPicker(); }

    protected override async Task OnInitializedAsync()
    {
        contentTypes = await ApiClient.GetContentTypesAsync();
        availableParents = await ApiClient.GetContentItemsAsync();

        if (IsEdit)
        {
            var existing = await ApiClient.GetContentItemByIdAsync(Id!);
            if (existing != null)
            {
                item = existing;
                selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
            }
        }
        
        isLoading = false;
    }

    private void OnContentTypeChanged()
    {
        selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
        // optionally clear data when switching content types in creation mode
        if (!IsEdit)
        {
            item.Data = new Dictionary<string, object>();
        }
    }

    private string GetContentTypeName(string id)
    {
        var ct = contentTypes.FirstOrDefault(c => c.Id == id);
        return ct != null ? $"{ct.DisplayName} ({ct.SystemName})" : id;
    }

    private string GetItemDisplayName(ContentItem ci)
    {
        if (ci.Data.TryGetValue("Title", out var t) || ci.Data.TryGetValue("title", out t) || 
            ci.Data.TryGetValue("Name", out t) || ci.Data.TryGetValue("name", out t))
        {
            if (t is JsonElement el && el.ValueKind == JsonValueKind.String)
                return el.GetString() ?? ci.Id;
            return t.ToString() ?? ci.Id;
        }
        return ci.Id;
    }

    private string GetStringValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            // System.Text.Json JsonElement parsing if coming from API
            if (value is JsonElement el) {
                if (el.ValueKind == JsonValueKind.String) return el.GetString() ?? "";
                if (el.ValueKind == JsonValueKind.Number) return el.GetRawText();
                return el.ToString();
            }
            return value.ToString() ?? "";
        }
        return "";
    }

    private bool GetBoolValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            if (value is JsonElement el && el.ValueKind == JsonValueKind.True) return true;
            if (value is bool b) return b;
            if (bool.TryParse(value.ToString(), out bool parsed)) return parsed;
        }
        return false;
    }

    private void SetValue(string fieldName, object? value)
    {
        if (value != null)
        {
            item.Data[fieldName] = value;
            
            // Auto-generate slug from title/name if slug is currently empty
            if (string.IsNullOrWhiteSpace(item.Slug) && 
                (fieldName.Equals("title", StringComparison.OrdinalIgnoreCase) || 
                 fieldName.Equals("name", StringComparison.OrdinalIgnoreCase)))
            {
                item.Slug = GenerateSlug(value.ToString());
            }
        }
        else
        {
            item.Data.Remove(fieldName);
        }
    }

    private string GenerateSlug(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;

        var str = text.ToLowerInvariant();
        str = System.Text.RegularExpressions.Regex.Replace(str, @"\s+", "-");
        str = System.Text.RegularExpressions.Regex.Replace(str, @"[^a-z0-9\-_]", "");
        return str.Trim('-');
    }

    private async Task HandleSubmit()
    {
        if (IsEdit)
        {
            await ApiClient.UpdateContentItemAsync(Id!, item);
        }
        else
        {
            item.Id = Guid.NewGuid().ToString(); // Assuming UUID generation handled client-side or we wait for API response
            await ApiClient.CreateContentItemAsync(item);
        }
        
        Navigation.NavigateTo("content-items");
    }

    private async Task UploadImageAsync(string fieldName, IBrowserFile file)
    {
        if (file is null) return;
        
        // Prevent SignalR stream deadlocks by fully downloading the file into memory 
        // before passing it to the synchronous/blocking HttpClient request pipeline.
        using var memoryStream = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);
        memoryStream.Position = 0;

        using var content = new MultipartFormDataContent();
        var fileContent = new StreamContent(memoryStream);
        fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
        content.Add(fileContent, "file", file.Name);

        var client = HttpClientFactory.CreateClient("MediaApi");
        var response = await client.PostAsync("/api/media", content);
        if (response.IsSuccessStatusCode)
        {
            var asset = await response.Content.ReadFromJsonAsync<MediaAsset>();
            if (asset != null && !string.IsNullOrEmpty(asset.Url))
            {
                SetValue(fieldName, asset.Url);
                await InvokeAsync(StateHasChanged);
            }
        }
    }
}
