@page "/content-types/new"
@page "/content-types/edit/{Id}"
@attribute [Authorize]

@inject BackofficeApiClient ApiClient
@inject NavigationManager Navigation
@inject ILogger<EditContentType> Logger

<PageTitle>@(IsEdit ? "Edit Content Type" : "New Content Type")</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@(IsEdit ? "Edit Content Type" : "New Content Type")</MudText>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit" FormName="ModifyContentType">
        <MudExitPrompt Disabled="@(!_hasUnsavedChanges)" />
        <MudGrid>
            <!-- Basic Info -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">General Information</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" Label="Display Name" Value="@contentType.DisplayName" ValueChanged="UpdateDisplayName" Required="true" Variant="Variant.Outlined" For="@(() => contentType.DisplayName)" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" Label="System Name" @bind-Value="contentType.SystemName" Required="true" Variant="Variant.Outlined" HelperText="Unique internal identifier" For="@(() => contentType.SystemName)" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string" Label="Slug" @bind-Value="contentType.Slug" Required="true" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentText="/content/" HelperText="Root URL for content items of this type" For="@(() => contentType.Slug)" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string" Label="Description" @bind-Value="contentType.Description" Variant="Variant.Outlined" Lines="2" For="@(() => contentType.Description)" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="PublishMode" Label="Publish Mode" @bind-Value="contentType.PublishMode" Required="true" Variant="Variant.Outlined" For="@(() => contentType.PublishMode)">
                                    @foreach (var mode in Enum.GetValues<PublishMode>())
                                    {
                                        <MudSelectItem Value="@mode">@mode.ToString()</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="string" Label="Template" @bind-Value="contentType.TemplateName"
                                    Variant="Variant.Outlined"
                                    HelperText="@(contentType.PublishMode == PublishMode.Headless ? "Seleziona un Publish Mode diverso da Headless per usare un template" : "Template grafico per la pubblicazione statica")"
                                    Clearable="true">
                                    @foreach (var t in availableTemplates)
                                    {
                                        <MudSelectItem Value="@t.FileName">
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                                                @t.DisplayName
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">(@t.FileName)</MudText>
                                            </div>
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>

                <!-- Fields Management -->
                <MudCard Elevation="1" Class="mt-6">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Fields Definition</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton ButtonType="ButtonType.Button" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Text" OnClick="AddField">Add Field</MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTable @key="contentType.Fields.Count" Items="@contentType.Fields" Elevation="0" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Pos</MudTh>
                                <MudTh>Label</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Required</MudTh>
                                <MudTh Style="text-align: right">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="field">
                                <MudTd DataLabel="Pos">
                                    <MudText Typo="Typo.body2">@(field.Position + 1)</MudText>
                                </MudTd>
                                <MudTd>
                                    <MudTextField @bind-Value="field.Name" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" Placeholder="e.g. Title" />
                                </MudTd>
                                <MudTd>
                                    <MudSelect T="ContentFieldType" @bind-Value="field.FieldType" Margin="Margin.Dense" Variant="Variant.Outlined">
                                        @foreach (var type in Enum.GetValues<ContentFieldType>())
                                        {
                                            <MudSelectItem Value="@type">@type.ToString()</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudTd>
                                <MudTd>
                                    <MudCheckBox @bind-Value="field.IsRequired" Color="Color.Primary" Dense="true" />
                                </MudTd>
                                <MudTd Style="text-align: right">
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Default" Size="Size.Small" OnClick="() => MoveFieldUp(field)" Disabled="@(field.Position == 0)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Color="Color.Default" Size="Size.Small" OnClick="() => MoveFieldDown(field)" Disabled="@(field.Position == contentType.Fields.Count - 1)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => RemoveField(field)" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                        @if (!contentType.Fields.Any())
                        {
                            <MudAlert Severity="Severity.Info" Class="mt-4">Nessun campo definito. Aggiungi almeno un campo per questo Content Type.</MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Sidebar Actions -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Actions</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="py-3">Save Content Type</MudButton>
                    </MudCardContent>
                </MudCard>
                <MudButton Href="content-types" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mt-4" FullWidth="true">Back to List</MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private bool isLoading = true;

    private ContentType contentType = new();
    private EditContext _editContext = default!;
    private bool _hasUnsavedChanges = false;
    private ContentTemplate[] availableTemplates = [];

    protected override async Task OnInitializedAsync()
    {
        availableTemplates = await ApiClient.GetContentTemplatesAsync();

        if (IsEdit)
        {
            var existing = await ApiClient.GetContentTypeByIdAsync(Id!);
            if (existing != null)
            {
                contentType = existing;
                contentType.Fields = contentType.Fields.OrderBy(f => f.Position).ToList();
            }
        }
        else
        {
            contentType.Fields = new List<ContentField>();
        }
        
        _editContext = new EditContext(contentType);
        _editContext.OnFieldChanged += (s, e) => { _hasUnsavedChanges = true; InvokeAsync(StateHasChanged); };
        
        isLoading = false;
    }

    private void UpdateDisplayName(string value)
    {
        contentType.DisplayName = value;
        _hasUnsavedChanges = true;
        
        if (!IsEdit)
        {
            if (string.IsNullOrWhiteSpace(contentType.SystemName) || contentType.SystemName == GenerateSystemName(oldDisplayName))
            {
                contentType.SystemName = GenerateSystemName(contentType.DisplayName);
            }
            
            if (string.IsNullOrWhiteSpace(contentType.Slug) || contentType.Slug == GenerateSlug(oldDisplayName))
            {
                contentType.Slug = GenerateSlug(contentType.DisplayName);
            }
            
            oldDisplayName = contentType.DisplayName;
        }
    }

    private async Task AddField()
    {
        if (contentType.Fields == null)
            contentType.Fields = new List<ContentField>();
            
        var nextPosition = contentType.Fields.Any() ? contentType.Fields.Max(f => f.Position) + 1 : 0;
        contentType.Fields.Add(new ContentField { FieldType = ContentFieldType.Text, Position = nextPosition });
        
        contentType.Fields = contentType.Fields.OrderBy(f => f.Position).ToList(); 
        _hasUnsavedChanges = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task MoveFieldUp(ContentField field)
    {
        var index = contentType.Fields.IndexOf(field);
        if (index > 0)
        {
            var other = contentType.Fields[index - 1];
            (field.Position, other.Position) = (other.Position, field.Position);
            contentType.Fields = contentType.Fields.OrderBy(f => f.Position).ToList();
            Logger.LogInformation("Field '{FieldName}' moved up to position {Position} in ContentType '{ContentTypeName}'", field.Name, field.Position, contentType.DisplayName);
            _hasUnsavedChanges = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task MoveFieldDown(ContentField field)
    {
        var index = contentType.Fields.IndexOf(field);
        if (index < contentType.Fields.Count - 1)
        {
            var other = contentType.Fields[index + 1];
            (field.Position, other.Position) = (other.Position, field.Position);
            contentType.Fields = contentType.Fields.OrderBy(f => f.Position).ToList();
            Logger.LogInformation("Field '{FieldName}' moved down to position {Position} in ContentType '{ContentTypeName}'", field.Name, field.Position, contentType.DisplayName);
            _hasUnsavedChanges = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RemoveField(ContentField field)
    {
        if (contentType.Fields != null)
        {
            contentType.Fields.Remove(field);
            // Re-normalize positions
            for (int i = 0; i < contentType.Fields.Count; i++)
            {
                contentType.Fields[i].Position = i;
            }
            contentType.Fields = contentType.Fields.ToList(); 
            _hasUnsavedChanges = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string oldDisplayName = string.Empty;

    private string GenerateSystemName(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        var str = System.Text.RegularExpressions.Regex.Replace(text, @"[^a-zA-Z0-9]", "");
        return str;
    }

    private string GenerateSlug(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        var str = text.ToLowerInvariant();
        str = System.Text.RegularExpressions.Regex.Replace(str, @"\s+", "-");
        str = System.Text.RegularExpressions.Regex.Replace(str, @"[^a-z0-9\-]", "");
        return str.Trim('-');
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(contentType.Slug))
        {
            // Fallback safety if validation bypassed
            return;
        }

        if (IsEdit)
        {
            await ApiClient.UpdateContentTypeAsync(Id!, contentType);
        }
        else
        {
            contentType.Id = Guid.NewGuid().ToString(); // Assuming string ID format handling
            await ApiClient.CreateContentTypeAsync(contentType);
        }
        
        _hasUnsavedChanges = false;
        StateHasChanged();
        await Task.Delay(10); // Give Blazor UI thread a tick to update MudExitPrompt
        
        Navigation.NavigateTo("content-types");
    }
}
