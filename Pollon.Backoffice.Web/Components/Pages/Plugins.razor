@page "/plugins"
@rendermode InteractiveServer
@attribute [Authorize]
@inject BackofficeApiClient ApiClient
@inject IDialogService DialogService
@attribute [StreamRendering]

<PageTitle>Plugins</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Registered Plugins</MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewIdentity">
            Create New Identity
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadDataAsync">
            Refresh
        </MudButton>
    </div>
</div>

@if (newCredentials != null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="my-4" CloseIcon="@Icons.Material.Filled.Close" CloseIconClicked="() => newCredentials = null">
        <MudText Typo="Typo.h6">New Plugin Identity Created!</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">Copy these credentials into your plugin configuration. You won't be able to see the secret again.</MudText>
        <div class="pa-4 mud-theme-dark rounded">
            <MudText Typo="Typo.body2"><b>Client ID:</b> <code>@newCredentials.ClientId</code></MudText>
            <MudText Typo="Typo.body2"><b>Client Secret:</b> <code>@newCredentials.ClientSecret</code></MudText>
        </div>
    </MudAlert>
}

<MudText Typo="Typo.body1" Class="mb-4">
    Total plugins registered: <b>@(plugins?.Length ?? 0)</b>
</MudText>

@if (errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="my-4">
        <MudText Typo="Typo.h6">Error fetching plugins:</MudText>
        <MudText Typo="Typo.body2">@errorMessage</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="LoadDataAsync" Class="mt-2">Retry</MudButton>
    </MudAlert>
}
else if (plugins == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <MudTable Items="@plugins" Hover="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="1">
        <HeaderContent>
            <MudTh>Status</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>ID / Instance</MudTh>
            <MudTh>Enabled types</MudTh>
            <MudTh>Last Seen</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Filled">
                    @context.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Name">
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.body1" Style="font-weight: 500">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="ID / Instance">
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.body2"><b>ID:</b> @context.Id</MudText>
                    <MudText Typo="Typo.caption" Style="font-family: monospace" Color="Color.Secondary">Instance: @context.ConsulServiceId</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Enabled types">
                @if (context.EnabledContentTypes?.Any() == true)
                {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var type in context.EnabledContentTypes)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@type</MudChip>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">None</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Last Seen">
                @context.LastSeen.ToLocalTime().ToString("g")
            </MudTd>
            <MudTd DataLabel="Actions">
                <div class="d-flex">
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Small" OnClick="() => ConfigurePlugin(context)" Title="Configure" />
                    <MudIconButton Icon="@Icons.Material.Filled.VpnKey" Color="Color.Warning" Size="Size.Small" OnClick="() => RegenerateIdentity(context.Id)" Title="Regenerate Secret" />
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" Size="Size.Small" OnClick="() => RevokeIdentity(context.Id)" Title="Revoke Identity" />
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No plugins registered yet.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private Pollon.Contracts.Models.PluginInfo[]? plugins;
    private string? errorMessage;
    private BackofficeApiClient.KeycloakCredentials? newCredentials;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task CreateNewIdentity()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };

        var dialog = await DialogService.ShowAsync<PluginIdentityDialog>("New Plugin Identity", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string pluginName)
        {
            try 
            {
                newCredentials = await ApiClient.CreatePluginIdentityAsync(pluginName);
                if (newCredentials == null)
                {
                    errorMessage = "Failed to create identity in Keycloak. Check logs.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
            }
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            errorMessage = null;
            plugins = await ApiClient.GetPluginsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task ConfigurePlugin(Pollon.Contracts.Models.PluginInfo plugin)
    {
        var parameters = new DialogParameters<PluginConfigDialog> { { x => x.Plugin, plugin } };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<PluginConfigDialog>("Configure Plugin", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDataAsync();
        }
    }

    private async Task RevokeIdentity(string clientId)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Revoke Identity", 
            "Are you sure you want to delete this plugin identity from Keycloak? The plugin will no longer be able to authenticate.", 
            yesText: "Revoke", cancelText: "Cancel");

        if (result == true)
        {
            try 
            {
                var success = await ApiClient.DeletePluginIdentityAsync(clientId);
                if (success)
                {
                    await DialogService.ShowMessageBoxAsync("Success", "Identity revoked successfully.");
                }
                else 
                {
                    errorMessage = "Failed to revoke identity. The client might not exist in Keycloak.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
            }
        }
    }

    private async Task RegenerateIdentity(string clientId)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Regenerate Secret", 
            "Are you sure you want to regenerate the secret for this plugin? You will need to update the plugin's configuration.", 
            yesText: "Regenerate", cancelText: "Cancel");

        if (result == true)
        {
            try 
            {
                newCredentials = await ApiClient.RegeneratePluginIdentityAsync(clientId);
                if (newCredentials == null)
                {
                    errorMessage = "Failed to regenerate secret.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = ex.Message;
            }
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Online" => Color.Success,
        "Warning" => Color.Warning,
        "Offline" => Color.Error,
        _ => Color.Default
    };
}
