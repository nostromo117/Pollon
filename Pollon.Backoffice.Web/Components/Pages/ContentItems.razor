@page "/content-items"
@rendermode InteractiveServer
@attribute [Authorize]
@inject BackofficeApiClient ApiClient
@attribute [StreamRendering]

<PageTitle>Content Items</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Content Items</MudText>
    <div class="d-flex gap-4 align-center">
        <MudSelect T="string" Label="Status" Value="selectedStatus" ValueChanged="OnStatusChanged" Dense="true" Margin="Margin.Dense" Class="mud-width-full" Style="min-width: 150px;">
            <MudSelectItem Value="@((string?)null)">All Statuses</MudSelectItem>
            <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
            <MudSelectItem Value="@("Published")">Published</MudSelectItem>
            <MudSelectItem Value="@("Archived")">Archived</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="content-items/new">
            New Content
        </MudButton>
    </div>
</div>

@if (errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="my-4">
        <MudText Typo="Typo.h6">Si è verificato un errore:</MudText>
        <MudText Typo="Typo.body2">@errorMessage</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="LoadDataAsync" Class="mt-2">Riprova</MudButton>
    </MudAlert>
}
else if (rootItems == null || contentTypes == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    @if (!rootItems.Any())
    {
        <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center justify-center border-dashed">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Default" Size="Size.Large" Class="mb-4" Style="opacity: 0.2" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">No content items found. Click "New Content" to create one.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="1" Class="mt-4 pa-2">
            <MudTreeView Items="@rootItems" Hover="true" Dense="true" ExpandOnClick="true">
                <ItemTemplate Context="treeContext">
                    <MudTreeViewItem @bind-Expanded="@treeContext.Expanded" Items="@treeContext.Children" Value="@treeContext.Value">
                        <Content>
                            <div class="d-flex align-center w-100 py-2">
                                <MudTreeViewItemToggleButton @bind-Expanded="@treeContext.Expanded" Visible="@(treeContext.Children != null && treeContext.Children.Any())" />
                                <MudIcon Icon="@GetItemIcon(treeContext.Value!)" Color="@(treeContext.Value?.Status == "Published" ? Color.Primary : Color.Default)" Class="mr-3" />
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.body1" Style="font-weight: 500">@GetItemDisplayName(treeContext.Value!)</MudText>
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetContentTypeName(treeContext.Value!.ContentTypeId)</MudText>
                                        <MudDivider Vertical="true" FlexItem="true" Style="height: 12px;" />
                                        <MudChip T="string" Color="@GetStatusColor(treeContext.Value!.Status)" Size="Size.Small" Variant="Variant.Text" Class="ma-0 pa-0" Style="height: 18px; font-size: 0.7rem;">@treeContext.Value!.Status</MudChip>
                                    </div>
                                </div>
                                <div class="d-flex gap-1 ml-4 justify-end actions-container" style="min-width: 80px;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" Href="@($"content-items/edit/{treeContext.Value!.Id}")" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteItem(treeContext.Value!.Id)" />
                                </div>
                            </div>
                        </Content>
                    </MudTreeViewItem>
                </ItemTemplate>
            </MudTreeView>
        </MudPaper>
    }
}

@code {
    private List<TreeItemData<ContentItem>>? rootItems;
    private ContentType[]? contentTypes;
    
    private string? selectedStatus;
    private string selectedSortBy = "CreatedAt";
    private bool sortDescending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task OnStatusChanged(string? value)
    {
        selectedStatus = value;
        await LoadDataAsync();
    }

    private string? errorMessage;

    private async Task LoadDataAsync()
    {
        try 
        {
            errorMessage = null;
            contentTypes = await ApiClient.GetContentTypesAsync();
            var items = await ApiClient.GetContentItemsAsync(selectedStatus, selectedSortBy, sortDescending);
            
            // Build tree
            rootItems = BuildTree(items);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            if (ex.InnerException != null) errorMessage += $" --> {ex.InnerException.Message}";
        }
    }

    private List<TreeItemData<ContentItem>> BuildTree(IEnumerable<ContentItem> items)
    {
        var allItems = items.Select(i => new TreeItemData<ContentItem> { Value = i }).ToList();
        var itemLookup = allItems.ToDictionary(i => i.Value!.Id, StringComparer.OrdinalIgnoreCase);
        var roots = new List<TreeItemData<ContentItem>>();

        foreach (var it in allItems)
        {
            var parentId = it.Value!.ParentId;
            if (string.IsNullOrEmpty(parentId) || !itemLookup.TryGetValue(parentId, out var parent))
            {
                roots.Add(it);
            }
            else
            {
                if (parent.Children == null) parent.Children = new List<TreeItemData<ContentItem>>();
                ((List<TreeItemData<ContentItem>>)parent.Children).Add(it);
            }
        }
        return roots;
    }

    private string GetContentTypeName(string id)
    {
        if (contentTypes == null) return id;
        var ct = contentTypes.FirstOrDefault(c => c.Id == id);
        return ct != null ? ct.DisplayName : id;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Published" => Color.Success,
        "Draft" => Color.Default,
        "Archived" => Color.Warning,
        _ => Color.Info
    };

    private string GetItemIcon(ContentItem ci)
    {
        if (!string.IsNullOrEmpty(ci.Icon)) return ci.Icon;
        return Icons.Material.Filled.Description;
    }

    private async Task DeleteItem(string id)
    {
        await ApiClient.DeleteContentItemAsync(id);
        await LoadDataAsync();
    }

    private string GetItemDisplayName(ContentItem ci)
    {
        if (ci.Data.TryGetValue("Title", out var t) || ci.Data.TryGetValue("title", out t) || 
            ci.Data.TryGetValue("Name", out t) || ci.Data.TryGetValue("name", out t))
        {
            if (t is System.Text.Json.JsonElement el && el.ValueKind == System.Text.Json.JsonValueKind.String)
                return el.GetString() ?? ci.Id;
            return t.ToString() ?? ci.Id;
        }
        return ci.Id;
    }
}
