{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "static-route": {
        "ClusterId": "minio-cluster",
        "Match": {
          "Path": "/published/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/published"
          },
          {
            "PathPrefix": "/pollon-static"
          }
        ]
      }
    },
    "Clusters": {
      "minio-cluster": {
        "Destinations": {
          "minio-dest": {
            "Address": "http://localhost:9000"
          }
        }
      }
    }
  }
}
