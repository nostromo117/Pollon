@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">Pollon Backoffice</MudText>
        <MudSpacer />
        <MudTooltip Text="GitHub Repo">
            <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Href="https://github.com/nostromo117/Pollon" Target="_blank" />
        </MudTooltip>
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        <AuthorizeView Context="authContext">
            <Authorized>
                <MudMenu @ref="_authMenu" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@(() => Navigation.NavigateTo("logout", true))">Logout</MudMenuItem>
                    </ChildContent>
                </MudMenu>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="px-1" Style="text-transform:none" OnClick="OnUserMenuClick">
                    <MudText Typo="Typo.body2" Class="ml-3 mr-2">@authContext.User.Identity?.Name</MudText>
                    <MudAvatar Color="Color.Secondary" Size="Size.Small">
                        @(authContext.User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                    </MudAvatar>
                </MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="@(() => Navigation.NavigateTo("login", true))">Accedi</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pt-16 px-8">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<MudPopoverProvider />

@code {
    private MudMenu _authMenu = default!;
    bool _drawerOpen = true;

    private async Task OnUserMenuClick(MouseEventArgs e)
    {
        await _authMenu.ToggleMenuAsync(e);
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1976d2", // MUI Blue
            Secondary = "#9c27b0",
            AppbarBackground = "#1976d2",
            DrawerBackground = "#ffffff",
            DrawerText = "#000000",
            Background = "#f5f5f5"
        },
        Typography = new Typography()
        {
            // Default typography is fine for now
        }
    };
}
