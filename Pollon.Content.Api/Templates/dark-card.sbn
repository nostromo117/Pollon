<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title ?? "Content Item" }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #0d0d0d;
            --surface: #181818;
            --surface-2: #222222;
            --border: #2e2e2e;
            --text: #e8e8e8;
            --text-muted: #888888;
            --accent: #7c3aed;
            --accent-2: #06b6d4;
            --accent-3: #f59e0b;
            --glow: rgba(124, 58, 237, 0.25);
        }

        html { font-size: 16px; scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Space Grotesk', sans-serif;
            min-height: 100vh;
            line-height: 1.7;
        }

        /* NOISE OVERLAY */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }

        .wrapper { position: relative; z-index: 1; }

        /* HEADER */
        header {
            border-bottom: 1px solid var(--border);
            padding: 20px 0;
            background: rgba(13,13,13,0.8);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 50;
        }
        .header-inner {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text);
            text-decoration: none;
        }
        .logo span {
            color: var(--accent);
        }
        .header-badge {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--accent-2);
            border: 1px solid var(--accent-2);
            padding: 4px 12px;
            border-radius: 2px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* HERO SECTION */
        .hero {
            max-width: 1100px;
            margin: 0 auto;
            padding: 80px 32px 64px;
        }
        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: 'Space Mono', monospace;
            font-size: 0.72rem;
            color: var(--accent);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
        }
        .hero-tag::before {
            content: '';
            width: 24px;
            height: 2px;
            background: var(--accent);
        }
        .hero h1 {
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 700;
            line-height: 1.1;
            letter-spacing: -1.5px;
            color: var(--text);
            max-width: 860px;
            margin-bottom: 32px;
        }
        .hero h1 em {
            font-style: normal;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
        }
        .meta-chip {
            font-family: 'Space Mono', monospace;
            font-size: 0.72rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .meta-chip .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent-3);
        }

        /* CONTENT GRID */
        .content-grid {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 32px 80px;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 32px;
            align-items: start;
        }

        /* FIELDS */
        .fields-list { display: flex; flex-direction: column; gap: 2px; }

        .field-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .field-card:hover {
            border-color: var(--accent);
            box-shadow: 0 0 24px var(--glow);
        }
        .field-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
        }
        .field-card-header .field-index {
            font-family: 'Space Mono', monospace;
            font-size: 0.65rem;
            color: var(--accent);
            min-width: 28px;
        }
        .field-card-header .field-key {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text-muted);
        }
        .field-card-body {
            padding: 20px;
            font-size: 1rem;
            line-height: 1.75;
            color: var(--text);
        }
        .field-card-body img {
            width: 100%;
            height: auto;
            border-radius: 4px;
            border: 1px solid var(--border);
        }

        /* SIDEBAR */
        .sidebar { display: flex; flex-direction: column; gap: 16px; }

        .sidebar-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
        }
        .sidebar-card-title {
            padding: 12px 20px;
            background: var(--surface-2);
            border-bottom: 1px solid var(--border);
            font-family: 'Space Mono', monospace;
            font-size: 0.68rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--accent-2);
        }
        .sidebar-card-body { padding: 20px; }
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }
        .info-row:last-child { border-bottom: none; }
        .info-row .key { color: var(--text-muted); font-size: 0.75rem; }
        .info-row .val {
            color: var(--text);
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            text-align: right;
            max-width: 160px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* GALLERY */
        .gallery-section {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 32px 80px;
        }
        .section-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }
        .section-header h2 {
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--accent-2);
        }
        .section-header::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 12px;
        }
        .gallery-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--border);
            aspect-ratio: 16/9;
            background: var(--surface);
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s, filter 0.4s;
            filter: grayscale(20%) brightness(0.9);
        }
        .gallery-item:hover img {
            transform: scale(1.04);
            filter: grayscale(0%) brightness(1);
        }
        .gallery-item::after {
            content: '';
            position: absolute;
            inset: 0;
            border: 1px solid transparent;
            border-radius: 8px;
            transition: border-color 0.2s;
        }
        .gallery-item:hover::after { border-color: var(--accent); }

        /* FOOTER */
        footer {
            border-top: 1px solid var(--border);
            padding: 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'Space Mono', monospace;
            font-size: 0.72rem;
            color: var(--text-muted);
            max-width: 1100px;
            margin: 0 auto;
        }

        @media (max-width: 768px) {
            .content-grid { grid-template-columns: 1fr; }
            .hero h1 { font-size: 2rem; }
        }
    </style>
</head>
<body>
<div class="wrapper">

    <header>
        <div class="header-inner">
            <a href="/" class="logo">Pollon<span>.</span></a>
            <div class="header-badge">{{ content_type }}</div>
        </div>
    </header>

    <div class="hero">
        <div class="hero-tag">{{ content_type }}</div>
        <h1><em>{{ title ?? "Senza titolo" }}</em></h1>
        <div class="hero-meta">
            <div class="meta-chip">
                <span class="dot"></span>
                {{ published_at | date.to_string "%d %B %Y" }}
            </div>
            <div class="meta-chip">
                <span class="dot" style="background: var(--accent-2);"></span>
                /{{ slug }}
            </div>
        </div>
    </div>

    <div class="content-grid">
        <!-- FIELDS -->
        <div class="fields-list">
            {{ $i = 0 }}
            {{ for pair in this -}}
                {{
                   $key = pair.key | string.downcase
                   if ($key == "title" || $key == "published_at" || $key == "id" || $key == "slug" || $key == "content_type" || $key == "images")
                      continue
                   end
                   $i = $i + 1
                }}
                <div class="field-card">
                    <div class="field-card-header">
                        <span class="field-index">{{ $i | string.pad_left 2 "0" }}</span>
                        <span class="field-key">{{ pair.key }}</span>
                    </div>
                    <div class="field-card-body">
                        {{- $val = "" + pair.value -}}
                        {{- if ($val | string.contains "/api/media/") || ($val | string.starts_with "http") -}}
                            <img src="{{ $val }}" alt="{{ pair.key }}" />
                        {{- else -}}
                            {{ pair.value }}
                        {{- end -}}
                    </div>
                </div>
            {{ end }}
        </div>

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-card">
                <div class="sidebar-card-title">Metadata</div>
                <div class="sidebar-card-body">
                    <div class="info-row">
                        <span class="key">Tipo</span>
                        <span class="val">{{ content_type }}</span>
                    </div>
                    <div class="info-row">
                        <span class="key">Pubblicato</span>
                        <span class="val">{{ published_at | date.to_string "%d/%m/%Y" }}</span>
                    </div>
                    <div class="info-row">
                        <span class="key">Slug</span>
                        <span class="val">/{{ slug }}</span>
                    </div>
                    <div class="info-row">
                        <span class="key">ID</span>
                        <span class="val">{{ id }}</span>
                    </div>
                </div>
            </div>
            <div class="sidebar-card">
                <div class="sidebar-card-title">Sistema</div>
                <div class="sidebar-card-body">
                    <div class="info-row">
                        <span class="key">CMS</span>
                        <span class="val">Pollon</span>
                    </div>
                    <div class="info-row">
                        <span class="key">Template</span>
                        <span class="val">dark-card.sbn</span>
                    </div>
                    <div class="info-row">
                        <span class="key">Anno</span>
                        <span class="val">{{ date.now.year }}</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    {{ if images }}
    <div class="gallery-section">
        <div class="section-header">
            <h2>Galleria</h2>
        </div>
        <div class="gallery-grid">
            {{ for img in images }}
            <div class="gallery-item">
                <img src="{{ img.url }}" alt="{{ img.alt }}" />
            </div>
            {{ end }}
        </div>
    </div>
    {{ end }}

    <footer>
        <span>&copy; {{ date.now.year }} Pollon CMS</span>
        <span>Template Dark Card</span>
    </footer>

</div>
</body>
</html>
