@page "/content-items/new"
@page "/content-items/edit/{Id}"
@rendermode InteractiveServer
@inject BackofficeApiClient ApiClient
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>@(IsEdit ? "Edit Content Item" : "New Content Item")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@(IsEdit ? "Edit Content Item" : "New Content Item")</h1>
    <a href="content-items" class="btn btn-outline-secondary">Back to List</a>
</div>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm Model="item" OnValidSubmit="HandleSubmit" FormName="ModifyContentItem">
        <div class="row">
            <!-- Left column: Main Content Fields -->
            <div class="col-md-8">
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-white fw-bold">Configuration</div>
                    <div class="card-body">
                        
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Content Type</label>
                            @if (IsEdit)
                            {
                                <input type="text" class="form-control" value="@GetContentTypeName(item.ContentTypeId)" disabled />
                            }
                            else
                            {
                                <InputSelect @bind-Value="item.ContentTypeId" class="form-select" @bind-Value:after="OnContentTypeChanged">
                                    <option value="">-- Select Content Type --</option>
                                    @foreach(var ct in contentTypes)
                                    {
                                        <option value="@ct.Id">@ct.DisplayName (@ct.SystemName)</option>
                                    }
                                </InputSelect>
                            }
                        </div>

                        <!-- Dynamic Fields -->
                        @if (selectedContentType != null && selectedContentType.Fields.Any())
                        {
                            <hr class="my-4" />
                            <h5 class="mb-3">Content Data</h5>

                            @foreach (var field in selectedContentType.Fields)
                            {
                                <div class="mb-3">
                                    <label class="form-label">@field.Name @(field.IsRequired ? "*" : "")</label>
                                    
                                    @if (field.FieldType == "boolean")
                                    {
                                        <div class="form-check form-switch">
                                            <input type="checkbox" class="form-check-input" checked="@GetBoolValue(field.Name)" @onchange="@(e => SetValue(field.Name, e.Value))" id="@($"field_{field.Name}")" />
                                        </div>
                                    }
                                    else if (field.FieldType == "number")
                                    {
                                        <input type="number" class="form-control" value="@GetStringValue(field.Name)" @onchange="@(e => SetValue(field.Name, e.Value))" required="@field.IsRequired" id="@($"field_{field.Name}")" />
                                    }
                                    else if (field.FieldType == "date")
                                    {
                                        <input type="date" class="form-control" value="@GetStringValue(field.Name)" @onchange="@(e => SetValue(field.Name, e.Value))" required="@field.IsRequired" id="@($"field_{field.Name}")" />
                                    }
                                    else if (field.FieldType == "richtext")
                                    {
                                        <textarea class="form-control" rows="5" @onchange="@(e => SetValue(field.Name, e.Value))" required="@field.IsRequired" id="@($"field_{field.Name}")">@GetStringValue(field.Name)</textarea>
                                    }
                                    else // text
                                    {
                                        <input type="text" class="form-control" value="@GetStringValue(field.Name)" @onchange="@(e => SetValue(field.Name, e.Value))" required="@field.IsRequired" id="@($"field_{field.Name}")" />
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Right column: Metadata & Publishing -->
            <div class="col-md-4">
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-white fw-bold">Publishing</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Status</label>
                            <InputSelect @bind-Value="item.Status" class="form-select">
                                <option value="Draft">Draft</option>
                                <option value="Published">Published</option>
                                <option value="Archived">Archived</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Slug</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted small">/</span>
                                <InputText @bind-Value="item.Slug" class="form-control" placeholder="seo-friendly-slug" />
                            </div>
                            <div class="form-text small text-muted">Used for the item URL.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Created By</label>
                            <InputText @bind-Value="item.CreatedBy" class="form-control" />
                        </div>

                        @if (IsEdit)
                        {
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold text-uppercase">Created At</label>
                                <input type="text" class="form-control-plaintext" readonly value="@item.CreatedAt.ToLocalTime().ToString("g")" />
                            </div>
                            @if (item.PublishedAt.HasValue)
                            {
                                <div class="mb-3">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Published At</label>
                                    <input type="text" class="form-control-plaintext" readonly value="@item.PublishedAt.Value.ToLocalTime().ToString("g")" />
                                </div>
                            }
                            @if (item.UpdatedAt.HasValue)
                            {
                                <div class="mb-3">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Last Updated</label>
                                    <input type="text" class="form-control-plaintext" readonly value="@item.UpdatedAt.Value.ToLocalTime().ToString("g")" />
                                </div>
                            }
                        }

                        <hr />
                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold" disabled="@(string.IsNullOrEmpty(item.ContentTypeId))">Save Content</button>
                    </div>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private bool isLoading = true;

    private ContentItem item = new() { Status = "Draft", CreatedBy = "System Admin", Data = new() };
    private ContentType[] contentTypes = Array.Empty<ContentType>();
    private ContentType? selectedContentType;

    protected override async Task OnInitializedAsync()
    {
        contentTypes = await ApiClient.GetContentTypesAsync();

        if (IsEdit)
        {
            var existing = await ApiClient.GetContentItemByIdAsync(Id!);
            if (existing != null)
            {
                item = existing;
                selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
            }
        }
        
        isLoading = false;
    }

    private void OnContentTypeChanged()
    {
        selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
        // optionally clear data when switching content types in creation mode
        if (!IsEdit)
        {
            item.Data = new Dictionary<string, object>();
        }
    }

    private string GetContentTypeName(string id)
    {
        var ct = contentTypes.FirstOrDefault(c => c.Id == id);
        return ct != null ? $"{ct.DisplayName} ({ct.SystemName})" : id;
    }

    private string GetStringValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            // System.Text.Json JsonElement parsing if coming from API
            if (value is JsonElement el) {
                if (el.ValueKind == JsonValueKind.String) return el.GetString() ?? "";
                if (el.ValueKind == JsonValueKind.Number) return el.GetRawText();
                return el.ToString();
            }
            return value.ToString() ?? "";
        }
        return "";
    }

    private bool GetBoolValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            if (value is JsonElement el && el.ValueKind == JsonValueKind.True) return true;
            if (value is bool b) return b;
            if (bool.TryParse(value.ToString(), out bool parsed)) return parsed;
        }
        return false;
    }

    private void SetValue(string fieldName, object? value)
    {
        if (value != null)
        {
            item.Data[fieldName] = value;
            
            // Auto-generate slug from title/name if slug is currently empty
            if (string.IsNullOrWhiteSpace(item.Slug) && 
                (fieldName.Equals("title", StringComparison.OrdinalIgnoreCase) || 
                 fieldName.Equals("name", StringComparison.OrdinalIgnoreCase)))
            {
                item.Slug = GenerateSlug(value.ToString());
            }
        }
        else
        {
            item.Data.Remove(fieldName);
        }
    }

    private string GenerateSlug(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;

        var str = text.ToLowerInvariant();
        str = System.Text.RegularExpressions.Regex.Replace(str, @"\s+", "-");
        str = System.Text.RegularExpressions.Regex.Replace(str, @"[^a-z0-9\-_]", "");
        return str.Trim('-');
    }

    private async Task HandleSubmit()
    {
        if (IsEdit)
        {
            await ApiClient.UpdateContentItemAsync(Id!, item);
        }
        else
        {
            item.Id = Guid.NewGuid().ToString(); // Assuming UUID generation handled client-side or we wait for API response
            await ApiClient.CreateContentItemAsync(item);
        }
        
        Navigation.NavigateTo("content-items");
    }
}
