@page "/article/{*slug}"
@using System.Text.Json
@using Pollon.Publication.Models
@inject ContentApiClient ContentApi

@if (_item == null)
{
    <div class="container mt-5 text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Caricamento...</span>
        </div>
    </div>
}
else
{
    <PageTitle>@_item.Slug</PageTitle>

    <div class="container mt-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">@_item.Slug</li>
            </ol>
        </nav>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <header class="mb-5">
                    <h1 class="display-4 fw-bold">
                        @if (!string.IsNullOrEmpty(_item.Icon))
                        {
                            <i class="@_item.Icon text-primary me-3"></i>
                        }
                        @_item.Slug
                    </h1>
                    <div class="text-muted mb-3">
                        <span class="me-3"><i class="bi bi-calendar"></i> @_item.PublishedAt.ToString("dd MMMM yyyy")</span>
                        <span><i class="bi bi-tag"></i> @_item.SystemName</span>
                    </div>
                    <hr />
                </header>

                <article class="content-body">
                    @if (_item.IsInteractive)
                    {
                        <div class="interactive-form-container mt-4 mb-5 p-4 border rounded shadow-sm bg-white">
                            <h3 class="mb-4 text-primary"><i class="bi bi-ui-checks me-2"></i> Compila il Modulo</h3>
                            
                            @if (_submissionSuccess)
                            {
                                <div class="alert alert-success d-flex align-items-center" role="alert">
                                    <i class="bi bi-check-circle-fill me-2 fs-4"></i>
                                    <div>
                                        <strong>Inviato!</strong> Grazie per aver compilato il modulo. La tua risposta è stata registrata.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <form @onsubmit="HandleFormSubmit">
                                    <div class="row g-4">
                                        @foreach (var field in _fields.OrderBy(f => f.Position))
                                        {
                                            <div class="col-12">
                                                <label class="form-label fw-bold">@field.Name @(field.IsRequired ? "*" : "")</label>
                                                
                                                @if (field.FieldType == ContentFieldType.Boolean)
                                                {
                                                    <div class="form-check form-switch p-0 ms-4">
                                                        <input class="form-check-input" type="checkbox" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))" id="@field.Name">
                                                        <label class="form-check-label text-muted" for="@field.Name">Abilita @field.Name</label>
                                                    </div>
                                                }
                                                else if (field.FieldType == ContentFieldType.Number)
                                                {
                                                    <input type="number" class="form-control form-control-lg" placeholder="Inserisci @field.Name" required="@field.IsRequired" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))" />
                                                }
                                                else if (field.FieldType == ContentFieldType.Date)
                                                {
                                                    <input type="date" class="form-control form-control-lg" required="@field.IsRequired" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))" />
                                                }
                                                else if (field.FieldType == ContentFieldType.RichText)
                                                {
                                                    <textarea class="form-control form-control-lg" rows="4" placeholder="Inserisci @field.Name" required="@field.IsRequired" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))"></textarea>
                                                }
                                                else if (field.FieldType == ContentFieldType.Image)
                                                {
                                                     <div class="input-group">
                                                        <span class="input-group-text"><i class="bi bi-image"></i></span>
                                                        <input type="url" class="form-control form-control-lg" placeholder="URL Immagine per @field.Name" required="@field.IsRequired" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))" />
                                                     </div>
                                                     <div class="form-text text-muted">Per ora, inserisci un URL pubblico per l'immagine.</div>
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control form-control-lg" placeholder="Inserisci @field.Name" required="@field.IsRequired" @onchange="@(e => UpdateFieldValue(field.Name, e.Value))" />
                                                }
                                            </div>
                                        }
                                        
                                        <div class="col-12 mt-5">
                                            <button type="submit" class="btn btn-primary btn-lg px-5 py-3 shadow-sm" disabled="@(_isSubmitting)">
                                                @if (_isSubmitting)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                    <span>Invio in corso...</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-send-fill me-2"></i> <span>Invia Risposta</span>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            }
                        </div>
                    }

                    @if (!_item.IsInteractive)
                    {
                        <div class="content-preview mb-4">
                            <h4 class="mb-4 text-secondary fw-light">Anteprima Contenuto</h4>
                            @if (!string.IsNullOrEmpty(_item.HtmlContent))
                            {
                                <div class="static-content">
                                    @((MarkupString)_item.HtmlContent)
                                </div>
                            }
                            else
                            {
                                <div class="mb-4">
                                    <h4 class="mb-4 border-bottom pb-2 text-primary fw-light">Specifiche Contenuto (Modo Headless)</h4>
                                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                                        @foreach (var property in ParseJson(_item.JsonData))
                                        {
                                            <div class="col">
                                                <div class="property-box p-2 rounded bg-light border">
                                                    <div class="overflow-hidden">
                                                        <div class="text-muted small fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05rem;">@property.Key</div>
                                                        @if (property.Value.StartsWith("/api/media/") || property.Value.StartsWith("http"))
                                                        {
                                                            <img src="@property.Value" class="img-fluid rounded mt-2" style="max-height: 200px; object-fit: contain;" alt="@property.Key" />
                                                        }
                                                        else
                                                        {
                                                            <div class="text-dark fw-semibold text-truncate" title="@property.Value" style="font-size: 0.9rem;">@property.Value</div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
            </article>

                <footer class="mt-5 pt-5 border-top text-center">
                    <a href="/" class="btn btn-outline-primary transition-all px-4 py-2">
                        <i class="bi bi-arrow-left me-2"></i> Torna alla lista
                    </a>
                </footer>
            </div>
        </div>
    </div>
}

<style>
    .transition-all {
        transition: all 0.3s ease;
    }
</style>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    private PublishedContent? _item;
    private List<ContentField> _fields = new();
    private Dictionary<string, object> _formData = new();
    private bool _isSubmitting;
    private bool _submissionSuccess;

    protected override async Task OnParametersSetAsync()
    {
        _item = await ContentApi.GetContentBySlugAsync(Slug);
        if (_item?.IsInteractive == true)
        {
            _fields = JsonSerializer.Deserialize<List<ContentField>>(_item.SchemaJson) ?? new();
            _formData = _fields.ToDictionary(f => f.Name, f => (object)(f.DefaultValue ?? ""));
            _submissionSuccess = false;
        }
    }

    private void UpdateFieldValue(string fieldName, object? value)
    {
        _formData[fieldName] = value ?? "";
    }

    private async Task HandleFormSubmit()
    {
        if (_item == null) return;
        _isSubmitting = true;
        try 
        {
            _submissionSuccess = await ContentApi.SubmitInteractiveContentAsync(_item.Id, _formData);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Submission failed: " + ex.Message);
        }
        finally 
        {
            _isSubmitting = false;
        }
    }

    private Dictionary<string, string> ParseJson(string json)
    {
        var result = new Dictionary<string, string>();
        try 
        {
            using var document = JsonDocument.Parse(json);
            foreach (var property in document.RootElement.EnumerateObject())
            {
                result[property.Name] = property.Value.ValueKind switch
                {
                    JsonValueKind.String => property.Value.GetString() ?? "",
                    JsonValueKind.Number => property.Value.GetRawText(),
                    JsonValueKind.True => "Sì",
                    JsonValueKind.False => "No",
                    JsonValueKind.Null => "-",
                    _ => property.Value.GetRawText()
                };
            }
        }
        catch 
        {
            result["Errore"] = "Impossibile analizzare i dati";
        }
        return result;
    }
}
