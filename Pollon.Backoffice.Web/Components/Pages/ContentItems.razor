@page "/content-items"
@rendermode InteractiveServer
@inject BackofficeApiClient ApiClient
@attribute [StreamRendering]

<PageTitle>Content Items</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-6">
    <MudText Typo="Typo.h4" GutterBottom="true">Content Items</MudText>
    <div class="d-flex gap-4 align-center">
        <MudSelect T="string" Label="Status" Value="selectedStatus" ValueChanged="OnStatusChanged" Dense="true" Margin="Margin.Dense" Class="mud-width-full" Style="min-width: 150px;">
            <MudSelectItem Value="@((string?)null)">All Statuses</MudSelectItem>
            <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
            <MudSelectItem Value="@("Published")">Published</MudSelectItem>
            <MudSelectItem Value="@("Archived")">Archived</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="content-items/new">
            New Content
        </MudButton>
    </div>
</div>

@if (contentItems == null || contentTypes == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <MudTable Items="@contentItems" Hover="true" Elevation="1" Dense="true" Class="mt-4">
        <HeaderContent>
            <MudTh>ContentType</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ContentItem, object>(x=>x.Status)">Status</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ContentItem, object>(x=>x.CreatedAt)" InitialDirection="SortDirection.Descending">Created</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ContentItem, object>(x=>x.PublishedAt!)">Published</MudTableSortLabel></MudTh>
            <MudTh Style="text-align: right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ContentType">
                <MudText Typo="Typo.body2" Style="font-weight: 600">@GetContentTypeName(context.ContentTypeId)</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Variant="Variant.Text">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Created">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@context.CreatedAt.ToLocalTime().ToString("g")</MudText>
            </MudTd>
            <MudTd DataLabel="Published">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.PublishedAt?.ToLocalTime().ToString("g") ?? "-")</MudText>
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" Href="@($"content-items/edit/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteItem(context.Id)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-4">No content items found. Click "New Content" to create one.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private ContentItem[]? contentItems;
    private ContentType[]? contentTypes;
    
    private string? selectedStatus;
    private string selectedSortBy = "CreatedAt";
    private bool sortDescending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task OnStatusChanged(string? value)
    {
        selectedStatus = value;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        contentTypes = await ApiClient.GetContentTypesAsync();
        contentItems = await ApiClient.GetContentItemsAsync(selectedStatus, selectedSortBy, sortDescending);
    }

    private string GetContentTypeName(string id)
    {
        if (contentTypes == null) return id;
        var ct = contentTypes.FirstOrDefault(c => c.Id == id);
        return ct != null ? ct.DisplayName : id;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Published" => Color.Success,
        "Draft" => Color.Default,
        "Archived" => Color.Warning,
        _ => Color.Info
    };

    private async Task DeleteItem(string id)
    {
        await ApiClient.DeleteContentItemAsync(id);
        await LoadDataAsync();
    }
}
