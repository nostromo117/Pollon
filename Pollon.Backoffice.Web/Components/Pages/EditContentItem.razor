@page "/content-items/new"
@page "/content-items/edit/{Id}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject BackofficeApiClient ApiClient
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject Pollon.Backoffice.Web.Services.IContentTreeService TreeService
@inject AuthenticationStateProvider AuthStateProvider
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web

<PageTitle>@(IsEdit ? $"Edit: {item.GetTitle()}" : "New Content Item")</PageTitle>

<MudGrid Class="mt-2" Spacing="4">
    <!-- Left Sidebar: Hierarchy & Search -->
    <MudItem xs="12" md="3">
        <MudPaper Elevation="0" Class="pa-4 border" Style="height: calc(100vh - 120px); display: flex; flex-direction: column;">
            <div class="d-flex align-center justify-space-between mb-2">
                <MudText Typo="Typo.h6">Navigation</MudText>
                <MudTooltip Text="New Root Item">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="CreateRootItem" />
                </MudTooltip>
            </div>

            <div class="mb-2">
                <MudTextField T="string" Label="Search Content..." @bind-Value="treeSearch" Immediate="true" 
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="ma-0 flex-none" Style="flex: 0 0 auto !important;" />
            </div>

            <div style="flex-grow: 1; overflow-y: auto; display: block;" class="mt-2">
                @if (allRoots == null)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                }
                else
                {
                    <div style="height: max-content; margin-top: 0;">
                        <MudTreeView Items="@FilteredRoots" Hover="true" T="ContentItem" 
                                     SelectionMode="SelectionMode.SingleSelection"
                                     ExpandOnClick="true" Dense="true" Class="pa-0">
                            <ItemTemplate Context="treeContext">
                                 <MudTreeViewItem Items="@treeContext.Children" Value="@treeContext.Value" 
                                                  @bind-Expanded="@treeContext.Expanded" 
                                                  Selected="@(treeContext.Value?.Id == Id)">
                                     <Content>
                                         <div style="width: 32px; display: flex; justify-content: center; align-items: center;">
                                             @if (treeContext.HasChildren)
                                             {
                                                 <MudTreeViewItemToggleButton @bind-Expanded="@treeContext.Expanded" />
                                             }
                                         </div>
                                         <div class="d-flex align-center py-2 flex-grow-1 cursor-pointer @(treeContext.Value?.Id == Id ? "mud-theme-primary-light rounded px-2" : "")" 
                                              @onclick='() => NavigateToItem(treeContext.Value?.Id)'>
                                             <MudIcon Icon="@TreeService.GetItemIcon(treeContext.Value!)" Size="Size.Small" Class="mr-3" 
                                                      Color="@(treeContext.Value?.Status == "Published" ? Color.Primary : Color.Default)" />
                                             <MudText Typo="Typo.body1" Class="text-truncate flex-grow-1" 
                                                      Style="@(treeContext.Value?.Id == Id ? "font-weight: 700" : "font-weight: 500")">
                                                 @treeContext.Value!.GetTitle()
                                             </MudText>
                                            <div @onclick:stopPropagation="true">
                                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" 
                                                               OnClick="@(() => AddChild(treeContext.Value?.Id))" />
                                            </div>
                                        </div>
                                    </Content>
                                </MudTreeViewItem>
                            </ItemTemplate>
                        </MudTreeView>
                    </div>
                }
            </div>
        </MudPaper>
    </MudItem>

    <!-- Right Content: Form -->
    <MudItem xs="12" md="9">
        <div class="d-flex justify-space-between align-center mb-6">
            <MudText Typo="Typo.h4">@(IsEdit ? "Edit Content Item" : "New Content Item")</MudText>
            <MudButton Href="content-items" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Back to List</MudButton>
        </div>

@if (isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmit" FormName="ModifyContentItem">
        <MudExitPrompt Disabled="@(!_hasUnsavedChanges)" />
        <MudGrid>
            <!-- Left column: Main Content Fields -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Configuration</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="mb-4">
                            @if (IsEdit)
                            {
                                <MudTextField Value="@GetContentTypeName(item.ContentTypeId)" Label="Content Type" ReadOnly="true" Variant="Variant.Outlined" />
                            }
                            else
                            {
                                <MudSelect T="string" Label="Content Type" @bind-Value="item.ContentTypeId" Variant="Variant.Outlined" @bind-Value:after="OnContentTypeChanged">
                                    <MudSelectItem Value="@("")">-- Select Content Type --</MudSelectItem>
                                    @foreach(var ct in contentTypes)
                                    {
                                        <MudSelectItem Value="@ct.Id">@ct.DisplayName (@ct.SystemName)</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </div>

                        <!-- Dynamic Fields -->
                        @if (selectedContentType != null && selectedContentType.Fields.Any())
                        {
                            <MudDivider Class="my-6" />
                            <MudText Typo="Typo.h6" Class="mb-4">Content Data</MudText>

                            <MudGrid>
                                @foreach (var field in selectedContentType.Fields)
                                {
                                    <MudItem xs="12">
                                        @if (field.FieldType == ContentFieldType.Boolean)
                                        {
                                            <MudSwitch T="bool" Value="@GetBoolValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Color="Color.Primary" Label="@field.Name" Class="mt-2" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Number)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" InputType="InputType.Number" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Date)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" InputType="InputType.Date" />
                                        }
                                        else if (field.FieldType == ContentFieldType.RichText)
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" Lines="5" HelperText="Supports HTML content" />
                                        }
                                        else if (field.FieldType == ContentFieldType.Image)
                                        {
                                            <div class="d-flex flex-column gap-2 mb-4">
                                                <MudText Typo="Typo.subtitle2">@field.Name</MudText>
                                                
                                                @if (!string.IsNullOrEmpty(GetStringValue(field.Name)))
                                                {
                                                    var imgUrl = GetStringValue(field.Name);
                                                    <div style="position: relative; max-width: 200px; min-height: 150px;">
                                                        @if (!_loadedImages.Contains(imgUrl))
                                                        {
                                                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Animation="Animation.Wave" Width="200px" Height="150px" Class="rounded absolute" Style="top:0;left:0;z-index:1;" />
                                                        }
                                                        <img src="@imgUrl" alt="@field.Name" class="mud-elevation-2 rounded" style="@(_loadedImages.Contains(imgUrl) ? "" : "opacity: 0;") max-width: 200px; max-height: 200px; object-fit: cover; position: relative; z-index:2; transition: opacity 0.3s ease-in;" @onload="@(() => OnImageLoaded(imgUrl))" />
                                                    </div>
                                                }

                                                <div class="mt-2">
                                                    @if (_isUploading)
                                                    {
                                                        <MudProgressLinear Color="Color.Primary" Value="_uploadProgress" Class="my-1" />
                                                        <MudText Typo="Typo.caption">Caricamento in corso: @(_uploadProgress.ToString("0"))%</MudText>
                                                    }
                                                    
                                                    <div style="@(_isUploading ? "display: none;" : "")">
                                                        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                                                            Upload Image
                                                            <InputFile @key="@($"input_{field.Name}")" OnChange="@(e => UploadImageAsync(field.Name, e.File))" accept=".jpg,.jpeg,.png,.webp,.gif" style="display:none;" />
                                                        </MudButton>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <MudTextField T="string" Label="@field.Name" Value="@GetStringValue(field.Name)" ValueChanged="@(v => SetValue(field.Name, v))" Immediate="true" Required="@field.IsRequired" Variant="Variant.Outlined" />
                                        }
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Right column: Metadata & Publishing -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Publishing</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="4">
                            <MudSelect T="string" Label="Status" @bind-Value="item.Status" Variant="Variant.Outlined">
                                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                                <MudSelectItem Value="@("Published")">Published</MudSelectItem>
                                <MudSelectItem Value="@("Archived")">Archived</MudSelectItem>
                            </MudSelect>

                            <MudSelect T="PublishMode?" Label="Publication Mode" @bind-Value="item.PublishModeOverride" Variant="Variant.Outlined" Clearable="true">
                                <MudSelectItem T="PublishMode?" Value="@(null)">Inherit: @(selectedContentType?.PublishMode.ToString() ?? "...")</MudSelectItem>
                                @foreach (var mode in Enum.GetValues<PublishMode>())
                                {
                                    <MudSelectItem T="PublishMode?" Value="@mode">@mode.ToString()</MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField T="string" Label="Slug" @bind-Value="item.Slug" Adornment="Adornment.Start" AdornmentText="@(selectedContentType != null && !string.IsNullOrWhiteSpace(selectedContentType.Slug) ? $"/{selectedContentType.Slug}/" : "/")" Variant="Variant.Outlined" HelperText="Used for the item URL." />

                        

                            <MudPaper Elevation="0" Class="pa-4 bg-light">
                                <MudText Typo="Typo.subtitle2" Color="Color.Inherit" Class="mb-2">Icon</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudPaper Width="48px" Height="48px" Class="d-flex align-center justify-center border bg-white">
                                        @if (!string.IsNullOrEmpty(item.Icon))
                                        {
                                            <MudIcon Icon="@GetMudIcon(item.Icon)" Color="Color.Primary" Size="Size.Large" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Default" Style="opacity: 0.25" Size="Size.Large" />
                                        }
                                    </MudPaper>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" Size="Size.Small" OnClick="ShowIconPicker">
                                        Select
                                    </MudButton>
                                    @if (!string.IsNullOrEmpty(item.Icon))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => item.Icon = null" />
                                    }
                                </MudStack>
                            </MudPaper>

                            <MudTextField T="string" Label="Created By" @bind-Value="item.CreatedBy" Variant="Variant.Outlined" ReadOnly="true" />

                            @if (IsEdit)
                            {
                                <MudField Label="Created At" Variant="Variant.Text">@item.CreatedAt.ToLocalTime().ToString("g")</MudField>
                                @if (item.PublishedAt.HasValue)
                                {
                                    <MudField Label="Published At" Variant="Variant.Text">@item.PublishedAt.Value.ToLocalTime().ToString("g")</MudField>
                                }
                                @if (item.UpdatedAt.HasValue)
                                {
                                    <MudField Label="Last Updated" Variant="Variant.Text">@item.UpdatedAt.Value.ToLocalTime().ToString("g")</MudField>
                                }
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="py-3" Disabled="@(string.IsNullOrEmpty(item.ContentTypeId))">Save Content</MudButton>
                    </MudCardActions>
                </MudCard>

                @if (item.Warnings.Any())
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-4" Icon="@Icons.Material.Filled.Warning">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: bold">Publication Warnings:</MudText>
                        <ul class="ml-4 mt-2">
                            @foreach (var warning in item.Warnings)
                            {
                                <li><MudText Typo="Typo.body2">@warning</MudText></li>
                            }
                        </ul>
                    </MudAlert>
                }
                
                <MudCard Elevation="1" Class="mt-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Media Gallery</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect T="string" Label="Seleziona Galleria" @bind-Value="item.GalleryId" Variant="Variant.Outlined" Clearable="true" HelperText="@(publishedGalleries.Any() ? "Collega una galleria a questo contenuto." : "Nessuna galleria pubblicata trovata. Vai in Media > Gallerie per pubblicarne una.")" @bind-Value:after="OnGalleryChanged">
                            <MudSelectItem T="string" Value="@((string?)null)">-- Nessuna --</MudSelectItem>
                            @foreach (var gal in publishedGalleries)
                            {
                                <MudSelectItem T="string" Value="@gal.Id">@gal.Name</MudSelectItem>
                            }
                        </MudSelect>

                        @if (selectedGallery != null && selectedGallery.AssetIds.Any())
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Anteprima Galleria</MudText>
                            <MudGrid Spacing="1">
                                @foreach (var assetId in selectedGallery.AssetIds)
                                {
                                    <MudItem xs="4">
                                        @{
                                            var galImgUrl = $"/api/media/{assetId}";
                                        }
                                        <div style="position: relative; width: 60px; height: 60px;">
                                            @if (!_loadedImages.Contains(galImgUrl))
                                            {
                                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Animation="Animation.Wave" Width="60px" Height="60px" Class="rounded absolute" Style="top:0;left:0;z-index:1;" />
                                            }
                                            <img src="@galImgUrl" class="rounded" style="@(_loadedImages.Contains(galImgUrl) ? "" : "opacity: 0;") width: 60px; height: 60px; object-fit: cover; position: relative; z-index:2; transition: opacity 0.3s ease-in;" @onload="@(() => OnImageLoaded(galImgUrl))" />
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
    <MudDialog @bind-Visible="showIconPicker" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Palette" Class="mr-3"/>Seleziona un'icona</MudText>
        </TitleContent>
        <DialogContent>
            <MudTextField T="string" Label="Cerca icona..." @bind-Value="iconSearch" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4" />
            <MudGrid Style="max-height: 400px; overflow-y: auto;">
                @foreach (var icon in FilteredIcons)
                {
                    <MudItem xs="4" sm="2">
                        <MudTooltip Text="@icon.Name">
                            <MudIconButton Icon="@GetMudIcon(icon.Val)" Color="Color.Default" Size="Size.Large" OnClick="() => SelectIcon(icon.Val)" Class="w-100 pa-4 mud-ripple shadow-none border" />
                        </MudTooltip>
                    </MudItem>
                }
            </MudGrid>
        </DialogContent>
    </MudDialog>
}
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public string? Id { get; set; }

    [SupplyParameterFromQuery]
    public string? ParentId { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private bool IsParentFixed => !string.IsNullOrEmpty(ParentId);
    private bool isLoading = true;

    private ContentItem item = new() { Status = "Draft", CreatedBy = "System Admin", Data = new() };
    private EditContext _editContext = default!;
    private bool _hasUnsavedChanges = false;
    private ContentType[] contentTypes = Array.Empty<ContentType>();
    private List<TreeItemData<ContentItem>> parentTreeItems = new();
    private List<TreeItemData<ContentItem>>? allRoots;
    private MediaGallery[] publishedGalleries = Array.Empty<MediaGallery>();
    private ContentType? selectedContentType;
    private MediaGallery? selectedGallery;

    private bool showParentSelector = false;
    private string treeSearch = "";

    private bool showIconPicker = false;
    private string iconSearch = "";
    private bool _isUploading = false;
    private double _uploadProgress = 0;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private HashSet<string> _loadedImages = new();

    private void OnImageLoaded(string url)
    {
        if (!_loadedImages.Contains(url))
        {
            _loadedImages.Add(url);
            InvokeAsync(StateHasChanged);
        }
    }

    private List<TreeItemData<ContentItem>> FilteredRoots => TreeService.ApplySearch(allRoots, treeSearch);


    private void NavigateToItem(string? id)
    {
        if (id == null) Navigation.NavigateTo("content-items/new");
        else Navigation.NavigateTo($"content-items/edit/{id}");
    }

    private void CreateRootItem()
    {
        Navigation.NavigateTo("content-items/new");
    }

    private void AddChild(string? parentId)
    {
        Navigation.NavigateTo($"content-items/new?parentId={parentId}");
    }

    private void ShowIconPicker() => showIconPicker = true;
    private void HideIconPicker() { showIconPicker = false; iconSearch = ""; }
    private void SelectIcon(string icon) { item.Icon = icon; _hasUnsavedChanges = true; HideIconPicker(); }


    private readonly List<(string Name, string Val)> AvailableIcons = new()
    {
        ("Casa", "fa-solid fa-home"), ("Utente", "fa-solid fa-user"), ("Articolo", "fa-solid fa-file-lines"),
        ("Immagine", "fa-solid fa-image"), ("Video", "fa-solid fa-video"), ("Musica", "fa-solid fa-music"),
        ("Prezzo", "fa-solid fa-tag"), ("Carrello", "fa-solid fa-cart-shopping"), ("Stella", "fa-solid fa-star"),
        ("Cuore", "fa-solid fa-heart"), ("Check", "fa-solid fa-check"), ("X", "fa-solid fa-xmark"),
        ("Info", "fa-solid fa-info-circle"), ("Attenzione", "fa-solid fa-warning"), ("Razzo", "fa-solid fa-rocket"),
        ("Mappa", "fa-solid fa-map"), ("Telefono", "fa-solid fa-phone"), ("Email", "fa-solid fa-envelope"),
        ("Calendario", "fa-solid fa-calendar"), ("Orologio", "fa-solid fa-clock"), ("Impostazioni", "fa-solid fa-gear"),
        ("Chiave", "fa-solid fa-key"), ("Lucchetto", "fa-solid fa-lock"), ("Grafico", "fa-solid fa-chart-line"),
        ("Nuvola", "fa-solid fa-cloud"), ("Fulmine", "fa-solid fa-bolt"), ("Fuoco", "fa-solid fa-fire"),
        ("Acqua", "fa-solid fa-droplet"), ("Foglia", "fa-solid fa-leaf"), ("Sole", "fa-solid fa-sun")
    };

    private IEnumerable<(string Name, string Val)> FilteredIcons => 
        string.IsNullOrWhiteSpace(iconSearch) 
            ? AvailableIcons 
            : AvailableIcons.Where(i => i.Name.Contains(iconSearch, StringComparison.OrdinalIgnoreCase) || i.Val.Contains(iconSearch, StringComparison.OrdinalIgnoreCase));

    private string? lastProcessedId;
    private IEnumerable<ContentItem>? cachedAllItems;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            contentTypes = await ApiClient.GetContentTypesAsync();
            publishedGalleries = await ApiClient.GetGalleriesAsync(includeUnpublished: false);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore nel caricamento dei metadati: " + ex.Message, Severity.Error);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        try 
        {
            // 1. Ensure hierarchy data is loaded once
            if (allRoots == null || cachedAllItems == null)
            {
                cachedAllItems = await ApiClient.GetContentItemsAsync();
                allRoots = TreeService.BuildTree(cachedAllItems);
            }

            // 2. Load or Reset the item
            if (IsEdit)
            {
                var existing = await ApiClient.GetContentItemByIdAsync(Id!);
                if (existing != null)
                {
                    item = existing;
                    selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
                    if (selectedContentType != null)
                    {
                        selectedContentType.Fields = selectedContentType.Fields.OrderBy(f => f.Position).ToList();
                    }
                    
                    if (!string.IsNullOrEmpty(item.GalleryId))
                    {
                        selectedGallery = await ApiClient.GetGalleryByIdAsync(item.GalleryId);
                    }
                }
            }
            else
            {
                // Reset for new item
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                var creator = user.Identity?.Name ?? "Unknown User";
                
                item = new ContentItem { Status = "Draft", CreatedBy = creator, Data = new(), ParentId = ParentId };
                selectedContentType = null;
                selectedGallery = null;
            }

            // 3. Update parent selection tree (using cached data)
            parentTreeItems = TreeService.BuildParentTree(cachedAllItems, Id);
            
            // 4. Update UI state (expand to current item if editing, or to parent if creating child)
            var targetIdToExpand = IsEdit ? Id : ParentId;
            if (!string.IsNullOrEmpty(targetIdToExpand))
            {
                TreeService.ExpandPathTo(allRoots, targetIdToExpand);
            }
            
            _editContext = new EditContext(item);
            _editContext.OnFieldChanged += (s, e) => { _hasUnsavedChanges = true; InvokeAsync(StateHasChanged); };
            _hasUnsavedChanges = false;
            
            lastProcessedId = Id;
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore nel caricamento: " + ex.Message, Severity.Error);
        }
        isLoading = false;
    }

    private async Task LoadSidebarAsync()
    {
        cachedAllItems = await ApiClient.GetContentItemsAsync();
        allRoots = TreeService.BuildTree(cachedAllItems);
        if (IsEdit) TreeService.ExpandPathTo(allRoots, Id!);
    }


    private void ToggleParentSelector() => showParentSelector = !showParentSelector;

    private void HandleParentFieldClick()
    {
        if (!IsParentFixed) ToggleParentSelector();
    }

    private void SelectParent(ContentItem? parent)
    {
        item.ParentId = parent?.Id;
        _hasUnsavedChanges = true;
        showParentSelector = false;
    }



    private string GetItemIcon(ContentItem ci)
    {
        return TreeService.GetItemIcon(ci);
    }

    private async Task OnGalleryChanged()
    {
        _hasUnsavedChanges = true;
        if (!string.IsNullOrEmpty(item.GalleryId))
        {
            selectedGallery = await ApiClient.GetGalleryByIdAsync(item.GalleryId);
        }
        else
        {
            selectedGallery = null;
        }
    }

    private void OnContentTypeChanged()
    {
        _hasUnsavedChanges = true;
        selectedContentType = contentTypes.FirstOrDefault(c => c.Id == item.ContentTypeId);
        if (selectedContentType != null)
        {
            selectedContentType.Fields = selectedContentType.Fields.OrderBy(f => f.Position).ToList();
        }
        // optionally clear data when switching content types in creation mode
        if (!IsEdit)
        {
            item.Data = new Dictionary<string, object>();
        }
    }

    private string GetContentTypeName(string id)
    {
        var ct = contentTypes.FirstOrDefault(c => c.Id == id);
        return ct != null ? $"{ct.DisplayName} ({ct.SystemName})" : id;
    }


    private string GetParentDisplayName()
    {
        if (string.IsNullOrEmpty(item.ParentId)) return "Nessuno";
        
        // Lookup in the flat list of all items or the tree
        var found = FindInTree(parentTreeItems, item.ParentId);
        return found != null ? found.Value!.GetTitle() : item.ParentId;
    }

    private TreeItemData<ContentItem>? FindInTree(IEnumerable<ITreeItemData<ContentItem>> items, string id)
    {
        foreach (var it in items)
        {
            if (string.Equals(it.Value?.Id, id, StringComparison.OrdinalIgnoreCase)) return (TreeItemData<ContentItem>)it;
            if (it.Children != null)
            {
                var found = FindInTree(it.Children, id);
                if (found != null) return found;
            }
        }
        return null;
    }

    private string GetStringValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            // System.Text.Json JsonElement parsing if coming from API
            if (value is JsonElement el) {
                if (el.ValueKind == JsonValueKind.String) return el.GetString() ?? "";
                if (el.ValueKind == JsonValueKind.Number) return el.GetRawText();
                return el.ToString();
            }
            return value.ToString() ?? "";
        }
        return "";
    }

    private bool GetBoolValue(string fieldName)
    {
        if (item.Data.TryGetValue(fieldName, out var value) && value != null)
        {
            if (value is JsonElement el && el.ValueKind == JsonValueKind.True) return true;
            if (value is bool b) return b;
            if (bool.TryParse(value.ToString(), out bool parsed)) return parsed;
        }
        return false;
    }

    private void SetValue(string fieldName, object? value)
    {
        _hasUnsavedChanges = true;
        if (value != null)
        {
            item.Data[fieldName] = value;
            
            // Auto-generate slug from title/name if slug is currently empty
            if (string.IsNullOrWhiteSpace(item.Slug) && 
                (fieldName.Equals("title", StringComparison.OrdinalIgnoreCase) || 
                 fieldName.Equals("name", StringComparison.OrdinalIgnoreCase)))
            {
                item.Slug = GenerateSlug(value.ToString());
            }
        }
        else
        {
            item.Data.Remove(fieldName);
        }
    }

    private string GenerateSlug(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;

        var str = text.ToLowerInvariant();
        str = System.Text.RegularExpressions.Regex.Replace(str, @"\s+", "-");
        str = System.Text.RegularExpressions.Regex.Replace(str, @"[^a-z0-9\-_]", "");
        return str.Trim('-');
    }

    private async Task HandleSubmit()
    {
        string? newId = Id;
        if (IsEdit)
        {
            await ApiClient.UpdateContentItemAsync(Id!, item);
        }
        else
        {
            item.Id = Guid.NewGuid().ToString();
            newId = item.Id;
            await ApiClient.CreateContentItemAsync(item);
        }
        
        if (item.Status == "Published")
        {
            Snackbar.Add("Richiesta di pubblicazione inviata. I plug-in stanno validando il contenuto.", Severity.Info);
        }
        else
        {
            Snackbar.Add($"Contenuto salvato con successo (Stato: {item.Status})", Severity.Success);
        }
        
        // Refresh sidebar
        await LoadSidebarAsync();
        
        _hasUnsavedChanges = false;
        StateHasChanged();
        await Task.Delay(10); // Give Blazor UI thread a tick to update MudExitPrompt
        
        // Navigate to the edit page of the item
        Navigation.NavigateTo($"content-items/edit/{newId}");
    }

    private async Task UploadImageAsync(string fieldName, IBrowserFile file)
    {
        if (file is null) return;
        
        _isUploading = true;
        _uploadProgress = 0;
        await InvokeAsync(StateHasChanged);

        try 
        {
            // Read the file in chunks to show progress
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            var buffer = new byte[81920]; // 80KB chunks
            int bytesRead;
            long totalRead = 0;

            while ((bytesRead = await stream.ReadAsync(buffer, 0, buffer.Length)) > 0)
            {
                await memoryStream.WriteAsync(buffer, 0, bytesRead);
                totalRead += bytesRead;
                _uploadProgress = (totalRead * 100.0) / file.Size;
                StateHasChanged();
            }

            memoryStream.Position = 0;

            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(memoryStream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var asset = await ApiClient.UploadMediaAsync(content);
            if (asset != null && !string.IsNullOrEmpty(asset.Url))
            {
                SetValue(fieldName, asset.Url);
                Snackbar.Add("Immagine caricata con successo", Severity.Success);
            }
            else
            {
                Snackbar.Add("Errore durante l'upload dell'immagine", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isUploading = false;
            _uploadProgress = 0;
            await InvokeAsync(StateHasChanged);
        }
    }
    private string GetMudIcon(string? icon) => icon ?? string.Empty;
